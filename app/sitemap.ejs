<?xml version="1.0" encoding="UTF-8"?>

<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc><%= origin %></loc>
    <priority>1.0</priority>
  </url>
  <url>
    <loc><%= origin %>/gowns</loc>
    <priority>1.0</priority>
  </url>
  <url>
    <loc><%= origin %>/sales</loc>
    <priority>1.0</priority>
  </url>
  <url>
    <loc><%= origin %>/accessories</loc>
    <priority>1.0</priority>
  </url>
  <%_ database.forEach(function(product) { _%>
  <url>
    <loc><%= origin %>/<%= product.category %>/<%= encodeSku(product.id) %></loc>
    <priority>0.5</priority>
  </url>
  <%_ }) _%>
</urlset>
